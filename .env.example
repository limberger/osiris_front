# Frontend environment example for Vercel
# Replace the values below with your production endpoints and secrets.

# API endpoints
# For Vite: VITE_API_URL / VITE_WS_URL
# For Next.js: NEXT_PUBLIC_API_URL / NEXT_PUBLIC_WS_URL
VITE_API_URL=https://api.example.com
VITE_WS_URL=wss://ws.example.com
NEXT_PUBLIC_API_URL=https://api.example.com
NEXT_PUBLIC_WS_URL=wss://ws.example.com

# OAuth2 (if frontend handles user login flow)
# Set the client ID in the frontend; keep client secret only in backend/Vercel secrets (do NOT expose in public frontend env)
OAUTH2_CLIENT_ID=your-client-id
OAUTH2_ISSUER=https://accounts.example.com
OAUTH2_REDIRECT_URI=https://your-site.vercel.app/auth/callback

# Feature flags / runtime
PUBLIC_ENABLE_DEBUG=false

# Example third-party keys (only if needed in frontend)
# e.g. Sentry DSN, analytics keys
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_ANALYTICS_KEY=

# Note for Vercel:
# - Add these variables under Project Settings → Environment Variables
# - Use the appropriate variable names for your framework (VITE_ for Vite, NEXT_PUBLIC_ for Next.js)
# - Put secrets (client secret, database credentials, JWT_SECRET) in the backend repository or Vercel Secrets (not here)
